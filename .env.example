# ── AI Provider Selection ────────────────────────────────────────────────────
# Choose one: anthropic | gemini | ollama
AI_PROVIDER=gemini

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (Local) ───────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434
